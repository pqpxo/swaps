  const key = await vaultDeriveKey(password, salt);
  const enc = new TextEncoder();
  const ct = await crypto.subtle.encrypt({
    name: 'AES-GCM',
    iv
  }, key, enc.encode(JSON.stringify(data)));
  return {
    salt: Array.from(salt),
    iv: Array.from(iv),
    ct: Array.from(new Uint8Array(ct))
  };
}
